async function schwabStatusPoll() {
  try {
    const r = await fetch('http://localhost:3001/health');
    const j = await r.json();
    const dot  = document.getElementById('schwab-status-dot');
    const txt  = document.getElementById('schwab-status-text');
    const btn  = document.getElementById('connect-btn');
    const lgt  = document.getElementById('logout-btn');
    if (j.connected) {
      dot.style.background = '#00e676';
      txt.textContent = 'Schwab Connected';
      txt.style.color  = '#00e676';
      btn.style.display = 'none';
      lgt.style.display = '';
    } else {
      dot.style.background = '#ff5252';
      txt.textContent = 'Schwab Disconnected';
      txt.style.color  = '#ff5252';
      btn.style.display = '';
      lgt.style.display = 'none';
      window._schwabAuthUrl = j.authUrl;
      window._schwabRedirectUri = j.redirectUri;
    }
  } catch (e) {
    const dot = document.getElementById('schwab-status-dot');
    const txt = document.getElementById('schwab-status-text');
    if (dot) dot.style.background = '#ffb300';
    if (txt) { txt.textContent = 'Proxy offline'; txt.style.color = '#ffb300'; }
  }
}

function schwabConnectToggle() {
  const panel = document.getElementById('schwab-auth-panel');
  panel.style.display = panel.style.display === 'none' ? 'block' : 'none';
}

function schwabAuthPanelClose() {
  document.getElementById('schwab-auth-panel').style.display = 'none';
  document.getElementById('schwab-url-input').value = '';
  document.getElementById('schwab-code-preview').style.display = 'none';
  document.getElementById('schwab-url-error').style.display = 'none';
  document.getElementById('schwab-submit-status').style.display = 'none';
  const btn = document.getElementById('schwab-submit-btn');
  btn.disabled = true;
  btn.style.background = '#1a3a1a';
  btn.style.borderColor = '#2a5a2a';
  btn.style.color = '#555';
  btn.style.cursor = 'not-allowed';
}

async function schwabOpenLogin() {
  if (!window._schwabAuthUrl) {
    try {
      const r = await fetch('http://localhost:3001/health');
      const j = await r.json();
      window._schwabAuthUrl = j.authUrl;
      window._schwabRedirectUri = j.redirectUri;
    } catch {
      alert('Proxy not running. Make sure node proxy.js is up on port 3001.');
      return;
    }
  }
  window.open(window._schwabAuthUrl, '_blank');
  document.getElementById('schwab-url-input').focus();
}

function schwabUrlChanged(val) {
  const preview = document.getElementById('schwab-code-preview');
  const errBox  = document.getElementById('schwab-url-error');
  const display = document.getElementById('schwab-code-display');
  const btn     = document.getElementById('schwab-submit-btn');

  preview.style.display = 'none';
  errBox.style.display  = 'none';
  btn.disabled = true;
  btn.style.background = '#1a3a1a';
  btn.style.borderColor = '#2a5a2a';
  btn.style.color = '#555';
  btn.style.cursor = 'not-allowed';

  if (!val.trim()) return;

  let code;
  try {
    const u = new URL(val.trim());
    code = u.searchParams.get('code');
  } catch {
    errBox.textContent = 'Not a valid URL — make sure you copied the full address bar URL.';
    errBox.style.display = 'block';
    return;
  }

  if (!code) {
    errBox.textContent = 'No "code" parameter found in this URL. Did you copy the right page?';
    errBox.style.display = 'block';
    return;
  }

  display.textContent = code.slice(0, 20) + '...';
  preview.style.display = 'block';
  btn.disabled = false;
  btn.style.background = '#003a1a';
  btn.style.borderColor = '#00b050';
  btn.style.color = '#00e676';
  btn.style.cursor = 'pointer';
}

async function schwabSubmitCode() {
  const val = document.getElementById('schwab-url-input').value.trim();
  const statusEl = document.getElementById('schwab-submit-status');
  const btn = document.getElementById('schwab-submit-btn');

  let code;
  try { code = new URL(val).searchParams.get('code'); } catch { return; }
  if (!code) return;

  btn.disabled = true;
  btn.textContent = 'Exchanging...';
  statusEl.style.display = 'block';
  statusEl.style.background = '#0a1628';
  statusEl.style.color = '#7a9bb5';
  statusEl.textContent = 'Sending code to proxy...';

  try {
    const resp = await fetch('http://localhost:3001/proxy/token', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ code, redirectUri: window._schwabRedirectUri || 'https://127.0.0.1:3001/callback' })
    });
    const body = await resp.json().catch(() => resp.text());
    if (resp.ok && body.connected) {
      statusEl.style.background = '#001a0d';
      statusEl.style.color = '#00e676';
      statusEl.textContent = '✓ Connected! Reloading dashboard...';
      setTimeout(() => { schwabAuthPanelClose(); schwabStatusPoll(); location.reload(); }, 1200);
    } else {
      const detail = typeof body === 'object' ? (body.details || body.error || JSON.stringify(body)) : body;
      statusEl.style.background = '#1a0000';
      statusEl.style.color = '#ff5252';
      statusEl.textContent = '✗ Failed: ' + detail;
      btn.disabled = false;
      btn.textContent = 'Exchange Code for Token';
    }
  } catch (e) {
    statusEl.style.background = '#1a0000';
    statusEl.style.color = '#ff5252';
    statusEl.textContent = '✗ Network error: ' + e.message;
    btn.disabled = false;
    btn.textContent = 'Exchange Code for Token';
  }
}


<script>
async function fetchESStats() {
  try {
    const SHEET_ID = '1NzeEb9KZgQQLIFkQ0ipxDPM2zQDBO1Yy-0As7O5q9Vg';
    const url = `https://docs.google.com/spreadsheets/d/${SHEET_ID}/gviz/tq?tqx=out:json&sheet=LEVELS`;
    const response = await fetch(url);
    const text = await response.text();
    const json = JSON.parse(text.substring(47).slice(0, -2));
    
    if (!json.table) return;
    
    const stats = {};
    const fmtESStat = value => {
      const n = parseFloat(String(value).replace(/[^0-9.-]/g, ''));
      return Number.isFinite(n) ? Math.round(n).toLocaleString('en-US') : value;
    };
    for (let row of json.table.rows) {
      const label = row.c[0]?.v;
      const value = row.c[1]?.v;
      if (label && value) {
        stats[label.toString().trim().toUpperCase()] = fmtESStat(value);
      }
    }
    
    if (stats['NO LONG']) {
      const el = document.getElementById('st-nolong-hi');
      if (el) el.textContent = stats['NO LONG'];
    }
    if (stats['UP']) {
      const el = document.getElementById('st-est-up');
      if (el) el.textContent = stats['UP'];
    }
    if (stats['VAH']) {
      const el = document.getElementById('st-vah');
      if (el) el.textContent = stats['VAH'];
    }
    if (stats['VPOC']) {
      const el = document.getElementById('st-vpoc');
      if (el) el.textContent = stats['VPOC'];
    }
    if (stats['MID']) {
      const el = document.getElementById('st-mid');
      if (el) el.textContent = stats['MID'];
    }
    if (stats['DOWN']) {
      const el = document.getElementById('st-est-dn');
      if (el) el.textContent = stats['DOWN'];
    }
    if (stats['VAL']) {
      const el = document.getElementById('st-val');
      if (el) el.textContent = stats['VAL'];
    }
    if (stats['NO SHORT']) {
      const el = document.getElementById('st-noshort-hi');
      if (el) el.textContent = stats['NO SHORT'];
    }
    
    // Store in window so we can restore if overwritten
    window.esStatsCache = stats;
  } catch (err) {
    console.error('Error fetching ES stats:', err);
  }
}

// Protect against overwrites by watching for changes and restoring
function protectESStats() {
  if (!window.esStatsCache) return;
  
  const ids = ['st-nolong-hi', 'st-est-up', 'st-vah', 'st-vpoc', 'st-mid', 'st-est-dn', 'st-val', 'st-noshort-hi'];
  const keyMap = {
    'st-nolong-hi': 'NO LONG',
    'st-est-up': 'UP',
    'st-vah': 'VAH',
    'st-vpoc': 'VPOC',
    'st-mid': 'MID',
    'st-est-dn': 'DOWN',
    'st-val': 'VAL',
    'st-noshort-hi': 'NO SHORT'
  };
  
  ids.forEach(id => {
    const el = document.getElementById(id);
    if (el && window.esStatsCache[keyMap[id]] && el.textContent === '—') {
      el.textContent = window.esStatsCache[keyMap[id]];
    }
  });
}

if (window.EventBus) {
  window.EventBus.on('page-changed', function(page) {
    if (page === 'overview') {
      setTimeout(fetchESStats, 200);
      // Protect every 1 second after page load
      setTimeout(() => {
        setInterval(protectESStats, 1000);
      }, 500);
    }
  });
}


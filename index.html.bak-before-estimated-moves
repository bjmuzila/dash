<!DOCTYPE html>
<html lang="en">
<head>
<script>
(() => {
  const originalFetch = window.fetch.bind(window);
  const failures = [];
  const dashboardAttempts = [];
  function rememberDashboardAttempt(kind, from, to) {
    dashboardAttempts.push(`${kind}: ${from}${to && to !== from ? ` -> ${to}` : ""}`);
    if (dashboardAttempts.length > 12) dashboardAttempts.shift();
  }
  function showDashboardAttempts() {
    const paint = () => {
      const existing = document.getElementById("dashboard-connection-monitor");
      if (existing) existing.remove();
      const panel = document.createElement("div");
      panel.id = "dashboard-connection-monitor";
      panel.style.cssText = [
        "position:fixed",
        "right:16px",
        "top:86px",
        "z-index:2147483647",
        "max-width:720px",
        "padding:12px 14px",
        "background:#050a10",
        "border:1px solid #00d8ff",
        "color:#cfefff",
        "font:12px/1.45 Consolas,monospace",
        "box-shadow:0 10px 30px rgba(0,0,0,.45)",
        "white-space:pre-wrap"
      ].join(";");
      panel.textContent = dashboardAttempts.length
        ? `Dashboard connection attempts:\n${dashboardAttempts.join("\n")}`
        : "Dashboard connection attempts: none recorded yet";
      document.body.appendChild(panel);
    };
    if (document.body) paint();
    else window.addEventListener("DOMContentLoaded", paint, { once: true });
  }
  setInterval(showDashboardAttempts, 3000);
  function rewriteDashboardUrl(value) {
    if (!value) return value;
    try {
      const parsed = new URL(String(value), location.href);
      if (parsed.hostname === "localhost" && parsed.port === "8080") {
        if (parsed.pathname.startsWith("/proxy/")) {
          parsed.port = "3001";
        }
      }
      if (parsed.pathname.startsWith("/api/")) {
        parsed.port = "3001";
        parsed.pathname = `/proxy${parsed.pathname}`;
      }
      return parsed.toString();
    } catch (_) {
      if (typeof value === "string" && value.startsWith("/api/")) return `/proxy${value}`;
      if (typeof value === "string" && value.startsWith("/proxy/")) return `http://localhost:3001${value}`;
      return value;
    }
  }
  function showDashboardLoadError(message) {
    const paint = () => {
      const existing = document.getElementById("dashboard-load-diagnostics");
      if (existing) existing.remove();
      const panel = document.createElement("div");
      panel.id = "dashboard-load-diagnostics";
      panel.style.cssText = [
        "position:fixed",
        "right:16px",
        "bottom:16px",
        "z-index:2147483647",
        "max-width:560px",
        "padding:14px 16px",
        "background:#100f14",
        "border:1px solid #ffcc00",
        "color:#f6f7fb",
        "font:12px/1.45 Consolas,monospace",
        "box-shadow:0 10px 30px rgba(0,0,0,.45)"
      ].join(";");
      panel.textContent = `Dashboard load blocked: ${message}`;
      document.body.appendChild(panel);
    };
    if (document.body) paint();
    else window.addEventListener("DOMContentLoaded", paint, { once: true });
  }
  window.addEventListener("error", (event) => {
    showDashboardLoadError(event.message || "script error");
  });
  window.addEventListener("unhandledrejection", (event) => {
    const reason = event.reason && (event.reason.stack || event.reason.message || String(event.reason));
    showDashboardLoadError(reason || "unhandled promise rejection");
  });
  window.fetch = async (input, init) => {
    const requestUrl = typeof input === "string" ? input : input && input.url;
    let rewrittenInput = input;
    if (typeof input === "string") {
      rewrittenInput = rewriteDashboardUrl(input);
    } else if (input && input.url && new URL(input.url, location.href).pathname.startsWith("/api/")) {
      rewrittenInput = new Request(rewriteDashboardUrl(input.url), input);
    } else if (input && input.url && new URL(input.url, location.href).port === "8080") {
      rewrittenInput = new Request(rewriteDashboardUrl(input.url), input);
    }
    rememberDashboardAttempt("fetch", requestUrl || String(input), typeof rewrittenInput === "string" ? rewrittenInput : rewrittenInput.url);
    try {
      const response = await originalFetch(rewrittenInput, init);
      if (!response.ok) {
        failures.push(`${response.status} ${requestUrl || response.url}`);
        showDashboardLoadError(failures.slice(-4).join(" | "));
      }
      return response;
    } catch (error) {
      failures.push(`${requestUrl || "fetch"}: ${error.message}`);
      showDashboardLoadError(failures.slice(-4).join(" | "));
      throw error;
    }
  };

  const NativeWebSocket = window.WebSocket;
  window.WebSocket = function DashboardWebSocket(url, protocols) {
    const originalUrl = String(url);
    let nextUrl = originalUrl;
    try {
      nextUrl = rewriteDashboardUrl(originalUrl).replace(/^http/, "ws");
    } catch (_) {}
    const socket = protocols === undefined ? new NativeWebSocket(nextUrl) : new NativeWebSocket(nextUrl, protocols);
    rememberDashboardAttempt("websocket", originalUrl, nextUrl);
    socket.addEventListener("error", () => {
      showDashboardLoadError(`WebSocket failed: ${originalUrl} -> ${nextUrl}`);
    });
    return socket;
  };
  window.WebSocket.prototype = NativeWebSocket.prototype;
  Object.defineProperty(window.WebSocket, "CONNECTING", { value: NativeWebSocket.CONNECTING });
  Object.defineProperty(window.WebSocket, "OPEN", { value: NativeWebSocket.OPEN });
  Object.defineProperty(window.WebSocket, "CLOSING", { value: NativeWebSocket.CLOSING });
  Object.defineProperty(window.WebSocket, "CLOSED", { value: NativeWebSocket.CLOSED });

  const NativeXMLHttpRequest = window.XMLHttpRequest;
  window.XMLHttpRequest = function DashboardXMLHttpRequest() {
    const xhr = new NativeXMLHttpRequest();
    const nativeOpen = xhr.open;
    xhr.open = function open(method, url, ...rest) {
      const nextUrl = rewriteDashboardUrl(url);
      rememberDashboardAttempt("xhr", `${method} ${url}`, nextUrl);
      return nativeOpen.call(xhr, method, nextUrl, ...rest);
    };
    xhr.addEventListener("loadend", () => {
      if (xhr.status >= 400) showDashboardLoadError(`XHR failed: ${xhr.status} ${xhr.responseURL}`);
    });
    return xhr;
  };

  if (window.EventSource) {
    const NativeEventSource = window.EventSource;
    window.EventSource = function DashboardEventSource(url, config) {
      const nextUrl = rewriteDashboardUrl(url);
      rememberDashboardAttempt("eventsource", String(url), nextUrl);
      const source = config === undefined ? new NativeEventSource(nextUrl) : new NativeEventSource(nextUrl, config);
      source.addEventListener("error", () => showDashboardLoadError(`EventSource failed: ${url} -> ${nextUrl}`));
      return source;
    };
    window.EventSource.prototype = NativeEventSource.prototype;
  }
})();
</script>
<script>
(() => {
  const fallbackMessages = [
    "Live data is still warming up.",
    "The dashboard shell is ready, but the overview did not finish its first render.",
    "Proxy status: check http://localhost:3001/proxy/api/status"
  ];

  function replaceStuckLoader() {
    const textNodes = [];
    const walker = document.createTreeWalker(document.body || document.documentElement, NodeFilter.SHOW_TEXT);
    while (walker.nextNode()) {
      if ((walker.currentNode.nodeValue || "").trim() === "Loading...") {
        textNodes.push(walker.currentNode);
      }
    }

    for (const node of textNodes) {
      const parent = node.parentElement;
      if (!parent || parent.dataset.loaderFallback === "true") continue;
      parent.dataset.loaderFallback = "true";
      parent.innerHTML = `
        <div style="display:grid;place-items:center;min-height:320px;color:#8fb7e8;font:13px Consolas,monospace;text-align:center">
          <div>
            <div style="color:#00d8ff;margin-bottom:10px">Overview waiting for first data packet</div>
            ${fallbackMessages.map((line) => `<div style="margin:4px 0">${line}</div>`).join("")}
          </div>
        </div>
      `;
    }
  }

  window.addEventListener("DOMContentLoaded", () => {
    setTimeout(replaceStuckLoader, 12000);
  });
})();
</script>

<script>
// ===========================
// PAGE LOADING SYSTEM
// ===========================

let currentPage = null;

function logStatsDebug(message) {
  return;
}

function resetLoadedPageScroll() {
  const panel = document.getElementById('content-panel');
  if (!panel) return;

  panel.scrollTop = 0;
  const scrollable = panel.querySelector('.content, .p-scroll-area, .main, .shell');
  if (scrollable) scrollable.scrollTop = 0;
  window.scrollTo(0, 0);
}

async function loadPage(pageName) {
  try {
    console.log(`Loading page: ${pageName}`);
    
    // Update nav active state
    document.querySelectorAll('.nav-item').forEach(item => {
      if (item.getAttribute('data-page') === pageName) {
        item.classList.add('active');
      } else {
        item.classList.remove('active');
      }
    });
    
    const panel = document.getElementById('content-panel');

    // Show loading state
    panel.innerHTML = `
      <div style="display:flex;align-items:center;justify-content:center;height:100%;color:#3a5570">
        <div style="display:flex;flex-direction:column;align-items:center;gap:12px">
          <div style="width:12px;height:12px;background:#00e5ff;border-radius:50%;animation:pulse 1s infinite"></div>
          <span style="font-size:12px;letter-spacing:.1em">Loading ${pageName}...</span>
        </div>
      </div>
    `;
    resetLoadedPageScroll();
    
    // Load the page HTML
    const response = await fetch(`pages/${pageName}.html`);
    if (!response.ok) {
      throw new Error(`Failed to load ${pageName}: ${response.statusText}`);
    }
    
    const html = await response.text();
    const doc = new DOMParser().parseFromString(html, 'text/html');
    const hasDocumentShell = /<!doctype|<html|<body/i.test(html);
    const pageContent = hasDocumentShell && doc.body && doc.body.childElementCount ? doc.body.innerHTML : html;
    panel.innerHTML = pageContent;
    if (pageName === 'overview') logStatsDebug('overview html injected from loadPage');
    if (hasDocumentShell) {
      doc.head.querySelectorAll('style, link[rel="stylesheet"]').forEach(node => {
        panel.prepend(document.importNode(node, true));
      });
    }
    resetLoadedPageScroll();

    // innerHTML doesn't execute <script> tags — manually re-execute them
    panel.querySelectorAll('script').forEach(oldScript => {
      const newScript = document.createElement('script');
      [...oldScript.attributes].forEach(a => newScript.setAttribute(a.name, a.value));
      newScript.textContent = oldScript.textContent;
      oldScript.parentNode.replaceChild(newScript, oldScript);
    });
    if (pageName === 'overview') logStatsDebug('overview inline scripts executed');
    
    // Call page-specific init function if it exists
    currentPage = pageName;
    window.AppState.currentPage = pageName;
    
    // Emit page-changed event
    window.EventBus.emit('page-changed', pageName);
    if (pageName === 'overview') logStatsDebug('page-changed event emitted');
    
    // Call init function if exists
    if (window[`init_${pageName}`]) {
      console.log(`Calling init_${pageName}()`);
      window[`init_${pageName}`]();
      if (pageName === 'overview') logStatsDebug(`init_${pageName} called`);
    }
    
    requestAnimationFrame(resetLoadedPageScroll);
    if (pageName === 'overview') logStatsDebug('loadPage complete');
    console.log(`✓ Page loaded: ${pageName}`);
  } catch (error) {
    console.error('Error loading page:', error);
    document.getElementById('content-panel').innerHTML = `
      <div style="display:flex;align-items:center;justify-content:center;height:100%;flex-direction:column;gap:12px">
        <div style="font-size:48px;opacity:0.2">⚠️</div>
        <div style="font-size:14px;color:#ff4757;font-weight:700">Failed to load ${pageName}</div>
        <div style="font-size:11px;color:#3a5570">${error.message}</div>
        <button class="btn btn-ghost btn-sm" onclick="loadPage('${pageName}')">↻ Retry</button>
      </div>
    `;
  }
}

